# Public site URL — used for sitemap, robots.txt, and OG image absolute URLs
# Set this to your production domain on Vercel (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Discord webhook URL — used by .github/scripts/notify-discord.js
# Get it from: Discord channel → Edit Channel → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Vercel credentials — used to wait for deployment before notifying Discord
# Token: vercel.com/account/tokens
# Project ID: vercel.com/your-project/settings → General → Project ID
VERCEL_TOKEN=...
VERCEL_PROJECT_ID=...
